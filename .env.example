# Copy to .env (gitignored) on the deploy host and fill in real values.
# docker compose reads .env automatically. After editing, re-run auto-update.sh
# (or `docker compose up -d --build`) so the container picks up the new env.

# --- Login notifications -----------------------------------------------------
# When a new user signs in for the first time, the server sends an email here.
# When unset, sign-ins are still written to /data/logins.log inside the
# container (host path: /home/wouter/llmlearn-data/logins.log).
NOTIFY_EMAIL=wouterdevriendt@gmail.com

# SMTP credentials. For Gmail use an app password (https://myaccount.google.com/apppasswords)
# — NOT your account password.
SMTP_HOST=smtp.gmail.com
SMTP_PORT=465
SMTP_USER=wouterdevriendt@gmail.com
SMTP_PASS=
SMTP_FROM=wouterdevriendt@gmail.com
