# Copy to .env (gitignored) on the deploy host and fill in real values.
# docker compose reads .env automatically. After editing, re-run auto-update.sh
# (or `docker compose up -d --build`) so the container picks up the new env.

# --- Login notifications (via AWS SES) --------------------------------------
# When a new user signs in for the first time, an email is sent here via SES.
# When NOTIFY_EMAIL is unset, sign-ins are still recorded to /data/logins.log
# inside the container (host path: /home/wouter/llmlearn-data/logins.log).
#
# AWS creds come from /home/wouter/.aws which is mounted read-only into the
# container — no secrets need to live in this file.
NOTIFY_EMAIL=wouterdevriendt@gmail.com

# Sender — must be on a verified SES identity (wdvr.dev is verified).
SES_FROM=llmlearn@wdvr.dev

# SES region. Default us-east-1 (matches ~/.aws/config).
AWS_REGION=us-east-1
